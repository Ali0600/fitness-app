# Dependencies
node_modules/

# Expo
.expo/
.expo-shared/
dist/
dist-*/
web-build/

# Native build outputs (generated by `expo prebuild`)
/ios/
/android/
*.orig.*

# Native credentials — NEVER commit these
*.jks
*.keystore
*.p8
*.p12
*.key
*.pem
*.mobileprovision
GoogleService-Info.plist
google-services.json

# EAS
.easignore

# Environment / secrets
.env
.env.*
!.env.example

# Metro / bundler
.metro-health-check*
metro.log

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Claude Code local settings
.claude/
CLAUDE.md

# Playwright MCP artifacts (test screenshots, console dumps)
.playwright-mcp/
playwright-report/
test-results/

# Local screenshots from manual testing (top-level only — keeps app/assets PNGs)
/*.png

# Temporary
tmp/
temp/
*.tmp
